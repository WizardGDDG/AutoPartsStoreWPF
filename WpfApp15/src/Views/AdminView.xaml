<UserControl x:Class="AutoPartsStoreWPF.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="АДМИНИСТРАТИВНАЯ ПАНЕЛЬ" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TabControl Grid.Row="1">
            <TabItem Header="Товары">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                        <Button Content="Добавить" Click="AddProduct"
                                Background="#2ECC71" Foreground="White" FontWeight="Bold"
                                Padding="15,8" Margin="5"/>
                        <Button Content="Обновить" Click="UpdateProduct"
                                Background="#3498DB" Foreground="White" FontWeight="Bold"
                                Padding="15,8" Margin="5"/>
                        <Button Content="Удалить" Click="DeleteProduct"
                                Background="#E74C3C" Foreground="White" FontWeight="Bold"
                                Padding="15,8" Margin="5"/>
                        <Button Content="Обновить список" Click="Refresh"
                                Background="#95A5A6" Foreground="White" FontWeight="Bold"
                                Padding="15,8" Margin="5"/>
                    </WrapPanel>

                    <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" 
                              CanUserAddRows="False" IsReadOnly="False" Height="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="80"/>
                            <DataGridTextColumn Header="Наличие" Binding="{Binding Stock}" Width="70"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Заказы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Новый статус:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox x:Name="cmbStatus" Width="120" Margin="5" Padding="5">
                            <ComboBoxItem Content="Новый"/>
                            <ComboBoxItem Content="В обработке"/>
                            <ComboBoxItem Content="Доставлен"/>
                            <ComboBoxItem Content="Отменен"/>
                        </ComboBox>
                        <Button Content="Обновить статус" Click="UpdateStatus"
                                Background="#F39C12" Foreground="White" FontWeight="Bold"
                                Padding="15,8" Margin="5"/>
                        <Button Content="Обновить список" Click="RefreshOrders"
                                Background="#95A5A6" Foreground="White" FontWeight="Bold"
                                Padding="15,8" Margin="5"/>
                    </WrapPanel>

                    <DataGrid x:Name="dgOrders" Grid.Row="1" AutoGenerateColumns="False" 
                              CanUserAddRows="False" IsReadOnly="True" Height="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Номер" Binding="{Binding OrderNumber}" Width="120"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding Customer.LastName}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=C}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>